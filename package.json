{
  "name": "pangolinfo-mcp",
  "version": "0.1.0",
  "description": "Pangolinfo MCP server - expose Pangolinfo scrape APIs to AI tooling via Model Context Protocol.",
  "type": "module",
  "bin": {
    "pangolinfo-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/server.js --banner:js=\"#!/usr/bin/env node\" --packages=external",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  }
}
