#!/bin/sh
#
# Pangolinfo MCP - 阿里云 ACR build + push 部署脚本 (模板)
#
# 用法:
#   1. 复制本模板为 deploy-mcp.sh:
#        cp deploy/deploy-mcp.sh.example deploy/deploy-mcp.sh
#   2. 在 deploy-mcp.sh 里填真实的 ACR_PASSWORD
#   3. 在 WSL 里运行 (注意要 WSL, Git Bash 网络栈不通阿里云国际版 ACR):
#        wsl ./deploy/deploy-mcp.sh 0.2.1
#
# deploy-mcp.sh 已经在 .gitignore 里, 不会被提交.
# 这个 .example 模板可以提交 (没密码).
#
# 参数:
#   $1 = 版本 tag (如 0.2.1), 必填. 不要用 latest, 留下版本足迹方便回滚.

set -e

VERSION="${1:?用法: $0 <version-tag>  例如: $0 0.2.1}"

# === ACR 凭据 ===
# 跟 scrapeapi 是同一套 (见 ../../crawler-ext-service/scripts/window/docker-scrapeapi.sh)
ACR_REGISTRY="registry-intl.ap-southeast-1.aliyuncs.com"
ACR_NAMESPACE="pangolinfo-prod"
ACR_USERNAME="lee@5913110905705115"
ACR_PASSWORD="<在这里填真实密码>"   # ← 必填. .gitignore 已经把 deploy-mcp.sh 拒绝了, 安全.

IMAGE_NAME="pangolinfo-mcp"
FULL_IMAGE="${ACR_REGISTRY}/${ACR_NAMESPACE}/${IMAGE_NAME}"

# === 切到 mcp 源码目录 (脚本在 deploy/ 下, 源码在上一层) ===
cd "$(dirname "$0")/.."

echo "=== Step 1: build :${VERSION} ==="
sudo docker build -t "${IMAGE_NAME}:${VERSION}" .

echo ""
echo "=== Step 2: tag for ACR ==="
sudo docker tag "${IMAGE_NAME}:${VERSION}" "${FULL_IMAGE}:${VERSION}"
sudo docker tag "${IMAGE_NAME}:${VERSION}" "${FULL_IMAGE}:latest"

echo ""
echo "=== Step 3: ACR login ==="
echo "${ACR_PASSWORD}" | sudo docker login --username="${ACR_USERNAME}" --password-stdin "${ACR_REGISTRY}"

echo ""
echo "=== Step 4: push :${VERSION} ==="
sudo docker push "${FULL_IMAGE}:${VERSION}"

echo ""
echo "=== Step 5: push :latest ==="
sudo docker push "${FULL_IMAGE}:latest"

echo ""
echo "=== Done ==="
echo "镜像已推送:"
echo "  ${FULL_IMAGE}:${VERSION}"
echo "  ${FULL_IMAGE}:latest"
echo ""
echo "现在去 ACK 控制台触发滚动更新:"
echo "  ACK -> 工作负载 -> 无状态 -> pangolinfo-mcp -> 升级"
echo "  把 image tag 从旧版本改成 ${VERSION} -> 提交"
echo "  2 个 Pod 自动一个一个滚动替换, 服务不中断."
